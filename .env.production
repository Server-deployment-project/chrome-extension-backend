# =========================================
# 生产环境配置 - Chrome Extension Backend
# 
# 警告：此文件包含敏感信息，请勿上传至代码仓库
# 部署时将此文件复制到服务器，设置文件权限：chmod 600 .env
# =========================================

# ===== 数据库配置 =====
DB_PASSWORD=changeme_strong_password_12345

# ===== LLM API 配置 =====
# 从 https://console.siliconflow.cn 获取 API Key
LLM_API_KEY=sk-your_production_api_key_here
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct

# ===== 应用配置 =====
# 应用版本号（用于镜像标签和部署追踪）
APP_VERSION=1.0.0
# 应用对外端口
APP_PORT=8000
# 时区配置
TZ=Asia/Shanghai

# ===== 日志配置 =====
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_EXTENSION_BACKEND=INFO

# ===== 监控告警配置 =====
# 告警Email（容器异常重启时使用）
ALERT_EMAIL=your_email@example.com
# 监控告警阈值：容器内存超过此比例时告警
MEMORY_THRESHOLD_PERCENT=80
# 监控告警阈值：CPU占用超过此比例时告警
CPU_THRESHOLD_PERCENT=75
